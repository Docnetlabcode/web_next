# Backend base URL. Set => direct calls (CORS must allow this origin).
# Leave blank => Next dev proxy rewrites /api + /socket.io to BACKEND_PROXY_TARGET.
NEXT_PUBLIC_API_BASE=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
BACKEND_PROXY_TARGET=https://api-service-gnxe.onrender.com

# WebRTC calling signaling lives in chat-service (port 5001), NOT api-service.
# Must point at the chat-service origin or call events never relay.
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:5001

# Optional TURN server (required for calls across different networks/NAT).
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_URL_TLS=turns:turn.example.com:5349
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_PASSWORD=pass

# --- Firebase Web config (public values from the Firebase console) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
