# =============================================================================
# Orovion web (Next.js) — environment template
#
#   cp .env.example .env.local   # then fill in the values
#
# All NEXT_PUBLIC_* values are inlined at BUILD time (`npm run build`), not
# read at runtime — set them before building (locally in .env.local, on
# Vercel in the project's Environment Variables) and rebuild after changes.
# =============================================================================


# =============================================================================
# 1) BACKEND — pick ONE of the three modes below
# =============================================================================
# The backend is deployed in TWO places (AWS + Render).
#
#   MODE A · DUAL DEPLOYMENT (production — active below)
#     On load the app probes each deployment's api-service GET /health and
#     uses AWS whenever it is up; Render takes over only when AWS is not
#     available. If the active deployment dies mid-session, requests +
#     sockets fail over to the other automatically.
#     A deployment's base can be a direct URL (must be https for a deployed
#     site) or the literal "proxy" = same-origin through THIS app's server.
#     The AWS box now runs Caddy and is reachable at https://api.orovion.com
#     (+ https://chat.orovion.com), so it is called DIRECTLY — the old "proxy"
#     workaround was only needed while AWS was plain http on a bare IP (mixed
#     content + un-storable Secure cookie). "proxy" still exists as a fallback
#     for any plain-http backend.
#
#   MODE B · SINGLE DEPLOYMENT
#     Comment out the Mode A pairs and set only the three Mode B vars.
#
#   MODE C · LOCAL DEV PROXY
#     Leave ALL API bases unset — every /api + /socket.io call goes
#     same-origin and the rewrites forward to the *_PROXY_TARGET vars.
#
# CORS: a DIRECT deployment's FRONTEND_URL env must include this site's
# origin, or its /health probe (and every API call) fails and traffic moves
# away from it. Proxied deployments don't involve CORS at all.
# Failover caveat: the refresh cookie lands on the active backend's domain
# (this site's own domain for a proxied one), so after an AWS <-> Render
# switch the user must sign in again.

# ----- MODE A: dual deployment (AWS primary, Render fallback) -----
# AWS · now HTTPS via Caddy, so the browser calls it DIRECTLY (no proxy).
#   api-service  → https://api.orovion.com
#   chat-service → https://chat.orovion.com   (Socket.IO / wss)
# The refresh cookie is set on .orovion.com (COOKIE_DOMAIN in the backend .env),
# so it persists first-party across orovion.com ↔ api.orovion.com.
NEXT_PUBLIC_API_BASE_AWS=https://api.orovion.com
NEXT_PUBLIC_SOCKET_URL_AWS=https://chat.orovion.com
# NEXT_PUBLIC_CHAT_SOCKET_URL_AWS=             # defaults to NEXT_PUBLIC_SOCKET_URL_AWS
# Legacy same-origin proxy targets — no longer needed for AWS (kept for local
# dev, Mode C). Only used when an API base is unset or set to the literal "proxy".
# BACKEND_PROXY_TARGET=https://api.orovion.com
# CHAT_PROXY_TARGET=https://chat.orovion.com

# Render · https, so the browser calls it directly.
NEXT_PUBLIC_API_BASE_RENDER=https://api-service-yd6j.onrender.com
# Render · chat-service origin (Socket.IO realtime + WebRTC call signaling).
NEXT_PUBLIC_SOCKET_URL_RENDER=https://chat-service-4ne7.onrender.com
# NEXT_PUBLIC_CHAT_SOCKET_URL_RENDER=          # defaults to NEXT_PUBLIC_SOCKET_URL_RENDER

# ----- MODE B: single deployment (used only when the Mode A pairs are unset) -----
# NEXT_PUBLIC_API_BASE=http://localhost:5000
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5001
# NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:5001

# ----- MODE C: local dev against a local backend -----
# Comment out the Mode A pairs and point the proxy targets at localhost:
# BACKEND_PROXY_TARGET=http://localhost:5000
# CHAT_PROXY_TARGET=http://localhost:5001


# =============================================================================
# 2) ADMIN CONSOLE (server-only; NOT NEXT_PUBLIC)
# =============================================================================
# The operator console is reachable ONLY at /<ADMIN_PANEL_SLUG>; the literal
# /admin path 404s. Use a long, non-obvious, per-deployment value so the real
# URL never ships in the client bundle and can't be guessed.
# NOTE: middleware runs on the Edge runtime, so Next inlines this at BUILD
# time — it must be present when you run `npm run build` (not only at runtime).
ADMIN_PANEL_SLUG=change-me-to-a-long-random-slug


# =============================================================================
# 3) WEBRTC CALLS (optional)
# =============================================================================
# TURN server — required for calls to connect across different networks/NAT.
# Without it, calls only work between peers that can reach each other directly.
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_URL_TLS=turns:turn.example.com:5349
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_PASSWORD=pass


# =============================================================================
# 4) FIREBASE WEB CONFIG (public values from the Firebase console)
# =============================================================================
# Firebase console -> Project settings -> Your apps -> Web app -> Config.
# Also add this site's domain under Authentication -> Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

